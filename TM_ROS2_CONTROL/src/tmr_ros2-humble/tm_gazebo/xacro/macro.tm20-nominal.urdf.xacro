<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find tm_gazebo)/xacro/macro.inertial.xacro" />

  <xacro:macro name="tm20" params="ns prefix color format dae_parse_gzskin
    joint_1_lower_limit:=${radians(-270)}    joint_1_upper_limit:=${radians(270)}
    joint_2_lower_limit:=${radians(-180)}    joint_2_upper_limit:=${radians(180)}
    joint_3_lower_limit:=${radians(-166)}    joint_3_upper_limit:=${radians(166)}
    joint_4_lower_limit:=${radians(-180)}    joint_4_upper_limit:=${radians(180)}
    joint_5_lower_limit:=${radians(-180)}    joint_5_upper_limit:=${radians(180)}
    joint_6_lower_limit:=${radians(-270)}    joint_6_upper_limit:=${radians(270)}
    joint_1_velocity_limit:=${radians(90)}
    joint_2_velocity_limit:=${radians(90)}
    joint_3_velocity_limit:=${radians(120)}
    joint_4_velocity_limit:=${radians(150)}
    joint_5_velocity_limit:=${radians(180)}
    joint_6_velocity_limit:=${radians(225)}
    joint_1_effort_limit:=${350}
    joint_2_effort_limit:=${350}
    joint_3_effort_limit:=${170}
    joint_4_effort_limit:=${45}
    joint_5_effort_limit:=${45}
    joint_6_effort_limit:=${45}
    safety_limits:=false safety_pos_margin:=0.15
    safety_k_position:=20">

    <xacro:property name="damping_factor" value="0.000"/>
    <xacro:property name="d1" value="${damping_factor*0.1}"/>
    <xacro:property name="d2" value="${damping_factor*0.1}"/>
    <xacro:property name="d3" value="${damping_factor*0.1}"/>
    <xacro:property name="d4" value="${damping_factor*0.1}"/>
    <xacro:property name="d5" value="${damping_factor*0.1}"/>
    <xacro:property name="d6" value="${damping_factor*0.1}"/>

    <xacro:property name="friction_factor" value="0.000"/>
    <xacro:property name="f1" value="${friction_factor*0.1}"/>
    <xacro:property name="f2" value="${friction_factor*0.1}"/>
    <xacro:property name="f3" value="${friction_factor*0.1}"/>
    <xacro:property name="f4" value="${friction_factor*0.1}"/>
    <xacro:property name="f5" value="${friction_factor*0.1}"/>
    <xacro:property name="f6" value="${friction_factor*0.1}"/>

    <!-- Inertia parameters -->
    <xacro:property name="mass_0" value="1.0" />
    <xacro:property name="mass_1" value="7.6" />
    <xacro:property name="mass_2" value="14.0239" />
    <xacro:property name="mass_3" value="3.3577" />
    <xacro:property name="mass_4" value="1.576" />
    <xacro:property name="mass_5" value="1.576" />
    <xacro:property name="mass_6" value="0.4" />

    <xacro:property name="unit_factor" value="0.000001"/>
    <xacro:property name="ixx_1" value="${20289.334*unit_factor}" />
    <xacro:property name="ixx_2" value="${71505.715*unit_factor}" />
    <xacro:property name="ixx_3" value="${9755.469*unit_factor}" />
    <xacro:property name="ixx_4" value="${2058.405*unit_factor}" />
    <xacro:property name="ixx_5" value="${2058.405*unit_factor}" />
    <xacro:property name="ixx_6" value="${476.643*unit_factor}" />

    <xacro:property name="iyy_1" value="${20289.334*unit_factor}" />
    <xacro:property name="iyy_2" value="${1175878.900*unit_factor}" />
    <xacro:property name="iyy_3" value="${163347.190*unit_factor}" />
    <xacro:property name="iyy_4" value="${2563.079*unit_factor}" />
    <xacro:property name="iyy_5" value="${2563.079*unit_factor}" />
    <xacro:property name="iyy_6" value="${851.576*unit_factor}" />
    
    <xacro:property name="izz_1" value="${21396.271*unit_factor}" />
    <xacro:property name="izz_2" value="${1203393.300*unit_factor}" />
    <xacro:property name="izz_3" value="${166566.78*unit_factor}" />
    <xacro:property name="izz_4" value="${2643.21*unit_factor}" />
    <xacro:property name="izz_5" value="${2643.21*unit_factor}" />
    <xacro:property name="izz_6" value="${959.690*unit_factor}" />

    <xacro:property name="specified_color_arms" default="false" />
    <xacro:property name="prefix_monochrome_command" default="true" />

    <!-- If other applications conflict with the color definition of URDF, try disable_prefix_color to close it -->
    <xacro:property name="disable_prefix_color" default="false" />
    <xacro:if value="${disable_prefix_color}">
      <prefix_monochrome_command value="false"/>
    </xacro:if>
    <xacro:if value="${format == 'stl'}">
      <specified_color_arms value="true"/>
      <prefix_monochrome_command value="false"/>
    </xacro:if>
    <xacro:if value="${format == 'dae'}">
      <specified_color_arms value="false"/>
      <prefix_monochrome_command value="false"/>
    </xacro:if>
    <xacro:if value="${prefix_monochrome_command}">
      <xacro:tm_materials/>
    </xacro:if>

    <!--LinkDescription-->
    <link name="${prefix}base_link">
      <visual>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm12/visual/tm12-base.${format}" />
        </geometry>
        <xacro:if value="${specified_color_arms}">
          <xacro:tm_material_whitegraphite />
        </xacro:if>
        <xacro:if value="${prefix_monochrome_command}">
          <material name="${color}" />
        </xacro:if>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm12/collision/tm12-base_c.stl" />
        </geometry>
      </collision>
      <xacro:cylinder_inertial_z radius="0.06" length="0.05" mass="${mass_0}">
        <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000" />
      </xacro:cylinder_inertial_z>
    </link>
    <joint name="${prefix}joint_1" type="revolute">
      <parent link="${prefix}base_link" />
      <child link="${prefix}link_1" />
      <origin rpy="0.000000 -0.000000 0.000000" xyz="0.000000 0.000000 0.165200" />
      <axis xyz="0 0 1" />
      <limit lower="${joint_1_lower_limit}" upper="${joint_1_upper_limit}" velocity="${joint_1_velocity_limit}" effort="${joint_1_effort_limit}" />
      <xacro:if value="${safety_limits}">
        <safety_controller soft_lower_limit="${joint_1_lower_limit + safety_pos_margin}" soft_upper_limit="${joint_1_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0" />
      </xacro:if>
      <dynamics damping="${d1}" friction="${f1}" />
    </joint>
    <link name="${prefix}link_1">
      <visual>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/visual/tm20-j1.${format}" />
        </geometry>
        <xacro:if value="${specified_color_arms}">
          <xacro:tm_material_darkolive />
        </xacro:if>
        <xacro:if value="${prefix_monochrome_command}">
          <material name="${color}" />
        </xacro:if>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/collision/tm20-j1_c.stl" />
        </geometry>
      </collision>
      <inertial>
        <mass value="${mass_1}" />
        <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000" />
      <inertia ixx="${ixx_1}" ixy="0.000000" ixz="0.000000" iyy="${iyy_1}" iyz="0.000000" izz="${izz_1}" />
      </inertial>
    </link>
    <joint name="${prefix}joint_2" type="revolute">
      <parent link="${prefix}link_1" />
      <child link="${prefix}link_2" />
      <origin rpy="-1.570796 -1.570796 0.000000" xyz="0.000000 0.000000 0.000000" />
      <axis xyz="0 0 1" />
      <limit lower="${joint_2_lower_limit}" upper="${joint_2_upper_limit}" velocity="${joint_2_velocity_limit}" effort="${joint_2_effort_limit}" />
      <xacro:if value="${safety_limits}">
        <safety_controller soft_lower_limit="${joint_2_lower_limit + safety_pos_margin}" soft_upper_limit="${joint_2_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0" />
      </xacro:if>
      <dynamics damping="${d2}" friction="${f2}" />
    </joint>
    <link name="${prefix}link_2">
      <visual>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/visual/tm20-arm1.${format}" />
        </geometry>
        <xacro:if value="${specified_color_arms}">
          <xacro:tm_material_darkolive />
        </xacro:if>
        <xacro:if value="${prefix_monochrome_command}">
          <material name="${color}" />
        </xacro:if>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/collision/tm20-arm1_c.stl" />
        </geometry>
      </collision>
      <inertial>
        <mass value="${mass_2}" />
        <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000" />
        <inertia ixx="${ixx_2}" ixy="0.000000" ixz="0.000000" iyy="${iyy_2}" iyz="0.000000" izz="${izz_2}" />
      </inertial>
    </link>
    <joint name="${prefix}joint_3" type="revolute">
      <parent link="${prefix}link_2" />
      <child link="${prefix}link_3" />
      <origin rpy="0.000000 -0.000000 0.000000" xyz="0.636100 0.000000 0.000000" />
      <axis xyz="0 0 1" />
      <limit lower="${joint_3_lower_limit}" upper="${joint_3_upper_limit}" velocity="${joint_3_velocity_limit}" effort="${joint_3_effort_limit}" />
      <xacro:if value="${safety_limits}">
        <safety_controller soft_lower_limit="${joint_3_lower_limit + safety_pos_margin}" soft_upper_limit="${joint_3_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0" />
      </xacro:if>
      <dynamics damping="${d3}" friction="${f3}" />
    </joint>
    <link name="${prefix}link_3">
      <visual>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/visual/tm20-arm2.${format}" />
        </geometry>
        <xacro:if value="${specified_color_arms}">
          <xacro:tm_material_gold />
        </xacro:if>
        <xacro:if value="${prefix_monochrome_command}">
          <material name="${color}" />
        </xacro:if>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/collision/tm20-arm2_c.stl" />
        </geometry>
      </collision>
      <inertial>
        <mass value="${mass_3}" />
        <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000" />
        <inertia ixx="${ixx_3}" ixy="0.000000" ixz="0.000000" iyy="${iyy_3}" iyz="0.000000" izz="${izz_3}" />
      </inertial>
    </link>
    <joint name="${prefix}joint_4" type="revolute">
      <parent link="${prefix}link_3" />
      <child link="${prefix}link_4" />
      <origin rpy="0.000000 -0.000000 1.570796" xyz="0.557900 0.000000 -0.156300" />
      <axis xyz="0 0 1" />
      <limit lower="${joint_4_lower_limit}" upper="${joint_4_upper_limit}" velocity="${joint_4_velocity_limit}" effort="${joint_4_effort_limit}" />
      <xacro:if value="${safety_limits}">
        <safety_controller soft_lower_limit="${joint_4_lower_limit + safety_pos_margin}" soft_upper_limit="${joint_4_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0" />
      </xacro:if>
      <dynamics damping="${d4}" friction="${f4}" />
    </joint>
    <link name="${prefix}link_4">
      <visual>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/visual/tm20-j5.${format}" />
        </geometry>
        <xacro:if value="${specified_color_arms}">
          <xacro:tm_material_darkolive />
        </xacro:if>
        <xacro:if value="${prefix_monochrome_command}">
          <material name="${color}" />
        </xacro:if>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/collision/tm20-j5_c.stl" />
        </geometry>
      </collision>
      <inertial>
        <mass value="${mass_4}" />      
        <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000"/>

        <inertia ixx="${ixx_4}" ixy="0.000000" ixz="0.000000" iyy="${iyy_4}" iyz="0.000000" izz="${izz_4}" />
      </inertial>
    </link>
    <joint name="${prefix}joint_5" type="revolute">
      <parent link="${prefix}link_4" />
      <child link="${prefix}link_5" />
      <origin rpy="1.570796 -0.000000 0.000000" xyz="0.000000 -0.106000 0.000000" />
      <axis xyz="0 0 1" />
      <limit lower="${joint_5_lower_limit}" upper="${joint_5_upper_limit}" velocity="${joint_5_velocity_limit}" effort="${joint_5_effort_limit}" />
      <xacro:if value="${safety_limits}">
        <safety_controller soft_lower_limit="${joint_5_lower_limit + safety_pos_margin}" soft_upper_limit="${joint_5_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0" />
      </xacro:if>
      <dynamics damping="${d5}" friction="${f5}" />
    </joint>
    <link name="${prefix}link_5">
      <visual>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/visual/tm20-j6.obj"/>
        </geometry>
        <xacro:if value="${specified_color_arms}">
          <xacro:tm_material_darkolive />
        </xacro:if>
        <xacro:if value="${prefix_monochrome_command}">
          <material name="${color}" />
        </xacro:if>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm20/collision/tm20-j6_c.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${mass_5}" />
        <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000" />
        <inertia ixx="${ixx_5}" ixy="0.000000" ixz="0.000000" iyy="${iyy_5}" iyz="0.000000" izz="${izz_5}" />
      </inertial>
    </link>
    <joint name="${prefix}joint_6" type="revolute">
      <parent link="${prefix}link_5" />
      <child link="${prefix}link_6" />
      <origin rpy="1.570796 -0.000000 0.000000" xyz="0.000000 -0.113150 0.000000" />
      <axis xyz="0 0 1" />
      <limit lower="${joint_6_lower_limit}" upper="${joint_6_upper_limit}" velocity="${joint_6_velocity_limit}" effort="${joint_6_effort_limit}" />
      <xacro:if value="${safety_limits}">
        <safety_controller soft_lower_limit="${joint_6_lower_limit + safety_pos_margin}" soft_upper_limit="${joint_6_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0" />
      </xacro:if>
      <dynamics damping="${d6}" friction="${f6}" />
    </joint>
    <link name="${prefix}link_6">
      <visual>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm5-900/visual/tmr_ee.${format}" />
        </geometry>
        <xacro:if value="${specified_color_arms}">
          <xacro:tm_material_purewhite />
        </xacro:if>
        <xacro:if value="${prefix_monochrome_command}">
          <material name="${color}" />
        </xacro:if>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://$(find tm_description)/meshes/tm5-900/collision/tmr_ee_c.stl" />
        </geometry>
      </collision>
      <inertial>
        <mass value="${mass_6}" />
        <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000" />
        <inertia ixx="${ixx_6}" ixy="0.000000" ixz="0.000000" iyy="${iyy_6}" iyz="0.000000" izz="${izz_6}" />
      </inertial>
    </link>

    <xacro:unless value="${dae_parse_gzskin}">
    <!-- gazebo material to the link -->
    <gazebo reference="base_link">
      <visual>
        <material>
          <ambient>0.941 0.929 0.882 1</ambient>
          <diffuse>0.941 0.929 0.882 1</diffuse>
          <specular>0.941 0.929 0.882 1</specular>
        </material>
      </visual>
    </gazebo>
  
    <gazebo reference="link_1">
      <visual>
        <material>
          <ambient>0.400 0.400 0.400 1</ambient>
          <diffuse>0.400 0.400 0.400 1</diffuse>
          <specular>0.400 0.400 0.400 1</specular>
        </material>
      </visual>
    </gazebo>

    <gazebo reference="link_2">
      <visual>
        <material>
          <ambient>0.400 0.400 0.400 1</ambient>
          <diffuse>0.400 0.400 0.400 1</diffuse>
          <specular>0.400 0.400 0.400 1</specular>
        </material>
      </visual>
    </gazebo>

    <gazebo reference="link_3">
      <visual>
        <material>
          <ambient>0.400 0.400 0.400 1</ambient>
          <diffuse>0.400 0.400 0.400 1</diffuse>
          <specular>0.400 0.400 0.400 1</specular>
        </material>
      </visual>
    </gazebo>

    <gazebo reference="link_4">
      <visual>
        <material>
          <ambient>0.400 0.400 0.400 1</ambient>
          <diffuse>0.400 0.400 0.400 1</diffuse>
          <specular>0.400 0.400 0.400 1</specular>
        </material>
      </visual>
    </gazebo>

    <gazebo reference="link_5">
      <visual>
        <material>
          <ambient>0.400 0.400 0.400 1</ambient>
          <diffuse>0.400 0.400 0.400 1</diffuse>
          <specular>0.400 0.400 0.400 1</specular>
        </material>
      </visual>
    </gazebo>

    <gazebo reference="link_6">
      <visual>
        <material>
          <ambient>0.941 0.929 0.882 1</ambient>
          <diffuse>0.941 0.929 0.882 1</diffuse>
          <specular>0.941 0.929 0.882 1</specular>
        </material>
      </visual>
    </gazebo>
    </xacro:unless>

    <!-- 'base' frame - base_link to base/World Coordinates transform -->
    <link name="${prefix}base" />
    <joint name="${prefix}base_link-base" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}base" />
      <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000" />
    </joint>

    <!-- 'flange' frame - attachment point for EEF models -->
    <link name="${prefix}flange" />
    <joint name="${prefix}joint_6-flange" type="fixed">
      <parent link="${prefix}link_6" />
      <child link="${prefix}flange" />
      <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000" />
    </joint>

    <!-- 'tool0' frame - all-zeros tool frame -->
    <link name="${prefix}tool0" />
    <joint name="${prefix}flange-tool0" type="fixed">
      <parent link="${prefix}flange" />
      <child link="${prefix}tool0" />
      <origin rpy="0.000000 0.000000 0.000000" xyz="0.000000 0.000000 0.000000" />
      <dynamics damping="0.0" friction="0.0"/>
    </joint>
    <!-- LinkDescription -->

  </xacro:macro>

</robot>
